{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "GestaltBI Config Editor",
  "version": "0.3.1",
  "identifier": "com.gestaltbi.configeditor",
  "build": {
    "beforeDevCommand": "npm start",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist/config-editor/browser"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "GestaltBI Config Editor",
        "width": 1280,
        "height": 800,
        "minWidth": 960,
        "minHeight": 600,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "category": "DeveloperTool",
    "shortDescription": "Author GestaltBI configuration repos visually",
    "longDescription": "Edit data structure, processing graph, and analysis modes for a GestaltBI instance. Pushes the config to a GitHub repo where the gestaltbi-core client can pick it up via /gh/<org>/<repo>.",
    "macOS": {
      "minimumSystemVersion": "10.15",
      "signingIdentity": "-"
    }
  },
  "plugins": {
    "dialog": {},
    "shell": {
      "open": true
    }
  }
}
